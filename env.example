# Copy to .env and set only the values needed for your deployment.

# Runtime
LOG_LEVEL=INFO
LOG_FILE=unified_mcp.log
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8001
COMMAND_TIMEOUT=300
OPERATION_TIMEOUT=300
MAX_CONCURRENT_COMMANDS=5
MAX_CONCURRENT_OPERATIONS=5

# HTTP security (streamable-http, sse, and openapi)
# Generate a long random value and send it as: Authorization: Bearer <value>
MCP_API_KEY=
# Comma-separated browser origins. This is not a replacement for MCP_API_KEY.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001

# Tool authorization: unrestricted (compatibility), read-only, or allowlist.
EXECUTION_POLICY=unrestricted
# Comma-separated parsed Azure CLI prefixes, used only in allowlist mode.
AZURE_COMMAND_ALLOWLIST=
# Comma-separated "METHOD /path" prefixes, used only in allowlist mode.
GRAPH_REQUEST_ALLOWLIST=

# Managed identity: preferred for workloads hosted in Azure.
# Leave MANAGED_IDENTITY_CLIENT_ID empty for a system-assigned identity.
USE_MANAGED_IDENTITY=false
MANAGED_IDENTITY_CLIENT_ID=

# Azure CLI service-principal authentication.
# Leave empty for interactive `az login` when using the local stdio transport.
AZURE_APP_TENANT_ID=
AZURE_APP_CLIENT_ID=
AZURE_APP_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Reuse the Azure service principal for Microsoft Graph.
SHARE_APP_REGISTRATION=false

# Microsoft Graph custom application authentication.
# Leave empty to use delegated device-code authentication and read-only scopes.
GRAPH_APP_CLIENT_ID=
GRAPH_APP_TENANT_ID=
GRAPH_APP_CLIENT_SECRET=

# Optional delegated-mode overrides.
GRAPH_TENANT_ID=common
GRAPH_CLIENT_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e
# Comma-separated delegated permissions. Defaults are read-only permissions.
# GRAPH_SCOPES=https://graph.microsoft.com/User.Read,https://graph.microsoft.com/Mail.Read

# Test-only switch. Never enable in a real deployment.
MOCK_MODE=false

# Backward-compatible aliases are still accepted:
# USE_APP_REG_CLIENTID, TENANTID, CLIENT_SECRET, GRAPH_CLIENT_SECRET
